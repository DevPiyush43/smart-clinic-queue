PORT=5000
MONGODB_URI=mongodb://localhost:27017/smart-clinic-queue
JWT_SECRET=replace_with_strong_secret_min_32_chars_here_1234
WEB_URL=http://localhost:5173
APP_URL=exp://192.168.1.x:8081
NODE_ENV=development

# Firebase (FCM) — optional, leave blank to stub
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@xxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Meta WhatsApp Cloud API OTP — optional, leave blank to stub
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_OTP_TEMPLATE_NAME=otp_auth

# ── Email OTP (Nodemailer / Gmail) ─────────────────────────────────────────
# Get a Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-gmail-app-password
EMAIL_FROM="Smart Clinic Queue <your-email@gmail.com>"
